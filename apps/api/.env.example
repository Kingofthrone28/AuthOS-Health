PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/authos_health
REDIS_URL=redis://localhost:6379
JWT_SECRET=change_me
INTERNAL_SECRET=change_me_internal
PAYER_URL=http://localhost:3006
WEB_URL=http://localhost:3000

# Voice calling
# Leave unset to auto-switch to Twilio when valid Twilio credentials are present.
VOICE_CALL_MODE=mock
MOCK_VOICE_CALL_DELAY_MS=3000
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+15551234567
# TWILIO_DEFAULT_PAYER_PHONE=+13479278846
# WORKER_PUBLIC_URL=https://your-public-worker-host.example.com
# TWILIO_TWIML_URL=https://your-public-worker-host.example.com/voice/twiml

# Single-tenant mode (set TENANT_MODE=single to enable)
# TENANT_MODE=single
# TENANT_NAME=My Org
# TENANT_SLUG=my-org
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change_me
