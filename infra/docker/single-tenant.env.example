# ─── Required ────────────────────────────────────────────────────────────────

# Tenant identity
TENANT_NAME="Acme Health System"
TENANT_SLUG=acme-health
ADMIN_EMAIL=admin@acme.health
ADMIN_NAME=Admin
ADMIN_PASSWORD=change_me_in_production

# Secrets
JWT_SECRET=generate-a-strong-random-string-here
INTERNAL_SECRET=generate-another-strong-random-string

# ─── Optional — SSO ─────────────────────────────────────────────────────────

# SSO_PROVIDER=oidc          # or "saml"
# SSO_ISSUER_URL=https://idp.acme.health
# SSO_CLIENT_ID=authos-health
# SSO_CLIENT_SECRET=...

# ─── Optional — external services ────────────────────────────────────────────

# PAYER_URL=https://payer-api.example.com
# FHIR_SERVER_URL=https://fhir.acme.health/r4
# WEB_URL=https://auth.acme.health

# ─── Optional — database (defaults to bundled Postgres) ─────────────────────

# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=authos_health
# POSTGRES_PORT=5432

# ─── Optional — ports ───────────────────────────────────────────────────────

# API_PORT=3001
# WEB_PORT=3000
# WORKER_VOICE_PORT=3002
# WORKER_WORKFLOW_PORT=3003
# REDIS_PORT=6379
